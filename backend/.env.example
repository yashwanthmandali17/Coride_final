# Database connection URL (Sqlite for local, or Postgres for Supabase/Production)
# Example Supabase: postgresql://postgres.xxxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./coride.db

# JWT Configuration
SECRET_KEY=generate_your_own_secure_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server configuration
PORT=8000
HOST=0.0.0.0
